# Copy this file to `.env` and fill in real values. Never commit `.env`.

PORT=4000
NODE_ENV=development

# MongoDB connection string (e.g. from MongoDB Atlas)
MONGO_URI=your_mongodb_connection_string

# Long, random secret used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_long_random_secret

# JWT lifetime (e.g. 15m, 24h, 7d)
TOKEN_EXPIRES=24h

# Comma-separated allowed browser origins for CORS in production.
# Leave blank in local dev to reflect any origin.
# Example: https://your-app.vercel.app,https://www.your-app.com
CLIENT_ORIGINS=
